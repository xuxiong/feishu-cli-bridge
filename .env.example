# Feishu app credentials
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# Webhook mode only: event token from Feishu callback settings.
FEISHU_VERIFICATION_TOKEN=xxx

# Webhook mode only: optional event encrypt key from Feishu callback settings.
# Leave empty if you did not configure Encrypt Key in Feishu.
FEISHU_ENCRYPT_KEY=

# API endpoint
FEISHU_API_BASE=https://open.feishu.cn
# Whether Feishu API calls should inherit HTTP(S)/SOCKS proxy env vars.
FEISHU_HTTP_TRUST_ENV=false

# Web service
APP_HOST=127.0.0.1
APP_PORT=8787

# Data
DATA_DIR=/Users/apple/feishu-cli-bridge/data
REPLAY_WINDOW_SECONDS=300
PENDING_TTL_SECONDS=300
MAX_TASK_LENGTH=1500
QUEUE_CONCURRENCY=1

# Command mapping
# Codex: non-interactive + auto approval/sandbox profile
CODEX_COMMAND="codex exec --full-auto"
# Gemini: non-interactive + yolo approval
GEMINI_COMMAND="gemini -p --approval-mode yolo"
# Qwen/CodeFree: one-shot with yolo approval
QWEN_COMMAND="qwen --approval-mode yolo"
CODEFREE_COMMAND="codefree --approval-mode yolo"
# Claude: non-interactive + bypass permission prompts
CLAUDE_COMMAND="claude -p --permission-mode bypassPermissions"

# Force all runner commands to execute only in this directory.
# Leave empty to disable restriction.
EXEC_WORKDIR=/Users/apple/owork/srdcloud/codefree-cli

# Reject run tasks that try to switch directory (cd/pushd/popd/chdir).
DISALLOW_DIR_SWITCH=true

# Reject run tasks that include dangerous operations (sudo/rm -rf/curl|sh/etc).
DISALLOW_DANGEROUS_TASK=true

# Set true to avoid real Feishu API calls in local tests
DRY_RUN=false
